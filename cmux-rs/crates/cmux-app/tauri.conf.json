{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cmux",
  "version": "0.0.1",
  "identifier": "ai.manaflow.cmux.rs",
  "build": {
    "beforeDevCommand": "pnpm --dir ../../ui dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --dir ../../ui build",
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "cmux (rust)",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
